# ── Required ──────────────────────────────────────────────────────────────────

# JSON-RPC endpoint (e.g. Infura, Alchemy, or local Anvil)
RPC_URL=http://127.0.0.1:8545

# Private key of the validator wallet (hex, no 0x prefix or with — both work)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed ValidationRegistry contract address
REGISTRY_ADDRESS=0xYOUR_REGISTRY_ADDRESS_HERE

# Router address this validator node monitors
ROUTER_ADDRESS=0xYOUR_ROUTER_ADDRESS_HERE

# Checksummed address of this validator's EOA wallet
# Used for sybil resistance: mandate signer must not equal this address
VALIDATOR_ADDRESS=0xYOUR_VALIDATOR_ADDRESS_HERE

# Public base URL of this service (used to construct responseURI)
BASE_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────

# Port for the local HTTP server (default: 3000)
SERVER_PORT=3000

# URI used by seed-request.ts and run-e2e.ts scripts
SEED_REQUEST_URI=http://localhost:3000/mock-payload
